# ========================================
# Gosimy eSIM Platform - Environment Variables
# ========================================
# Copy this file to .env.local and fill in your values
# ========================================

# ----------------------------------------
# Required for Production
# ----------------------------------------

# Application URL — set per environment in .env.development / .env.production
# NEXT_PUBLIC_APP_URL=

# Maintenance / Coming Soon mode ('true' or 'false') — set per environment
# MAINTENANCE_MODE=

# Supabase (Required)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Dodo Payments (Required)
# ========================================
# TEST ENVIRONMENT (Development)
# ----------------------------------------
# Use test API keys from Dodo Dashboard: https://dashboard.dodopayments.com
# Test Card: 4242 4242 4242 4242 (any future date, any CVV)
# The app automatically uses test_mode when NEXT_PUBLIC_APP_URL contains 'localhost'
# 
# DODO_PAYMENTS_API_KEY=test_xxxxxxxxxxxxx
# DODO_PAYMENTS_PRODUCT_ID=pdt_test_xxxxxxxxxxxxx
# DODO_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
#
# PRODUCTION ENVIRONMENT (Live)
# ----------------------------------------
# Use live API keys from Dodo Dashboard
# These should be set in Vercel as Production Environment Variables
#
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
# DODO_PAYMENTS_API_KEY=lj6CKLKGUvGL0Aed.... (live key)
# DODO_PAYMENTS_PRODUCT_ID=pdt_xxxxxxxxxxxxx
# DODO_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
#
# NOTES:
# - NEVER commit real API keys to git
# - Use different product IDs for test vs live in Dodo Dashboard
# - Set production variables in Vercel: Settings → Environment Variables
# ========================================

# Dodo Payments - Add your keys below
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_PRODUCT_ID=
DODO_WEBHOOK_SECRET=

# Dodo Payments Environment (Optional)
# Set to 'test' to force test mode, 'live' for live mode
# Defaults to test_mode when NEXT_PUBLIC_APP_URL contains 'localhost'
# DODO_PAYMENTS_ENVIRONMENT=test

# eSIM Access API (Required)
ESIM_ACCESS_API_KEY=
ESIM_ACCESS_SECRET_KEY=

# Resend Email (Required)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Security (Required)
CRON_SECRET=

# ----------------------------------------
# Optional / Recommended
# ----------------------------------------

# Admin Alerts
ADMIN_WEBHOOK_URL=
ADMIN_API_KEY=

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Error Tracking (Sentry)
NEXT_PUBLIC_SENTRY_DSN=

# ----------------------------------------
# Auto-configured by Vercel
# ----------------------------------------
# VERCEL_ENV
# VERCEL_GIT_COMMIT_SHA
# NODE_ENV
